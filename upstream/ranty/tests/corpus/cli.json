{
  "cases": [
    {
      "name": "cli_help_mentions_ranty_and_supported_flags",
      "kind": "simple",
      "args": [
        "--help"
      ],
      "stdin": null,
      "expectedStatus": 0,
      "expectedStdout": null,
      "stdoutIncludes": [
        "Command-line interface for Ranty",
        "--bench-mode",
        "--no-debug"
      ],
      "stderrIncludes": [],
      "stderrExcludes": [],
      "observed": {
        "status": 0,
        "stdout": "Ranty CLI 1.0.0\nCommand-line interface for Ranty\n\nUSAGE:\n    ranty [FLAGS] [OPTIONS] [FILE]\n\nFLAGS:\n    -b, --bench-mode     Enables benchmarking\n    -h, --help           Prints help information\n    -D, --no-debug       Disable emitting debug symbols (may improve performance)\n    -W, --no-warnings    Disables compiler warnings\n    -V, --version        Prints version information\n\nOPTIONS:\n    -e, --eval <PROGRAM_STRING>    Runs an inline program string; takes precedence over FILE and stdin\n    -s, --seed <SEED>              Specifies the initial 64-bit hex seed (1 to 16 hex digits, optional 0x prefix)\n\nARGS:\n    <FILE>    Runs a Ranty file if --eval is not used\n",
        "stderr": ""
      }
    },
