    {
      "name": "cli_can_suppress_warnings",
      "kind": "paired-simple",
      "first": {
        "args": [
          "--eval",
          "<$unused = 1>ok"
        ],
        "stdin": null,
        "expectedStatus": 0,
        "stderrIncludes": [
          "defined but never used"
        ],
        "stderrExcludes": [],
        "observed": {
          "status": 0,
          "stdout": "ok\n",
          "stderr": "\nwarning[R1000]: variable 'unused' is defined but never used\n --> (cmdline):1:2\n  |\n1 | <$unused = 1>ok\n  |  ^^^^^^^^^^^\n\n"
        }
      },
      "second": {
        "args": [
          "--no-warnings",
          "--eval",
          "<$unused = 1>ok"
        ],
        "stdin": null,
        "expectedStatus": 0,
        "stderrIncludes": [],
        "stderrExcludes": [
          "defined but never used"
        ],
        "observed": {
          "status": 0,
          "stdout": "ok\n",
          "stderr": ""
        }
      }
    },
